# Server
PORT=3001

# Auth
JWT_SECRET=generate-a-random-64-char-string-here

# Database
DATABASE_PATH=./data/meal-planner.db

# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Invite code for registration (leave empty to allow open registration in dev)
INVITE_CODE=

# CORS (set to frontend URL in production, e.g. https://your-app.vercel.app)
CORS_ORIGIN=
